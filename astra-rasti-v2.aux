\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Causal inference analysis of 1000\nobreakspace  {}Gaia DR2 stars. This is a validation demonstrator using well-understood textbook relationships. \textsc  {Astra}\xspace  correctly identifies: absolute magnitude $\rightarrow $ luminosity (definition); distance $\rightarrow $ apparent magnitude (inverse square law); and correctly excludes distance $\rightarrow $ absolute magnitude (selection bias/Malmquist bias).}}{9}{figure.4}\protected@file@percent }
\newlabel{fig:causal}{{4}{9}{Causal inference analysis of 1000~Gaia DR2 stars. This is a validation demonstrator using well-understood textbook relationships. \astra correctly identifies: absolute magnitude $\rightarrow $ luminosity (definition); distance $\rightarrow $ apparent magnitude (inverse square law); and correctly excludes distance $\rightarrow $ absolute magnitude (selection bias/Malmquist bias)}{figure.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.2}Results}{9}{subsection.7.2}\protected@file@percent }
